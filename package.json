{
  "name": "aws-s3-sdk-but-good",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ci:required": "pnpm build && pnpm typecheck && pnpm lint && pnpm test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && vitest run tests/infrastructure/",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:verify": "pnpm build && bash tooling/scripts/release-readiness-check.sh",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.27.0",
    "@s3-good-internal/shared": "workspace:*",
    "@size-limit/file": "^12.0.0",
    "prettier": "^3.0.0",
    "size-limit": "^12.0.0",
    "turbo": "^2.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.30.3"
}
