{
  "name": "@s3-good/core",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./hono": {
      "import": "./dist/hono.js",
      "types": "./dist/hono.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@s3-good/shared": "workspace:*",
    "sqids": "^0.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "hono": "^4.12.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@s3-good/react": "workspace:*",
    "hono": ">=4.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "@s3-good/react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
