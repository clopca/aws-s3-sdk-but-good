{
  "name": "s3-good",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/server.cjs",
  "module": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "typesVersions": {
    "*": {
      "server": [
        "dist/server.d.ts"
      ],
      "client": [
        "dist/client.d.ts"
      ],
      "next": [
        "dist/next.d.ts"
      ],
      "types": [
        "dist/types.d.ts"
      ],
      "hono": [
        "dist/hono.d.ts"
      ],
      "sdk": [
        "dist/sdk/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "require": "./dist/sdk/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "sqids": "^0.3.0"
  },
  "devDependencies": {
    "@s3-good/eslint-config": "workspace:*",
    "@s3-good-internal/shared": "workspace:*",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.2",
    "hono": "^4.12.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clopca/aws-s3-sdk-but-good.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/clopca/aws-s3-sdk-but-good/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/clopca/aws-s3-sdk-but-good/issues"
  }
}
