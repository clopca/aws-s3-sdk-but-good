{
  "name": "@s3-good/core",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/server.cjs",
  "module": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.cts",
        "default": "./dist/next.cjs"
      }
    },
    "./next-client": {
      "import": {
        "types": "./dist/next-client.d.ts",
        "default": "./dist/next-client.js"
      },
      "require": {
        "types": "./dist/next-client.d.cts",
        "default": "./dist/next-client.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/hono.d.ts",
        "default": "./dist/hono.js"
      },
      "require": {
        "types": "./dist/hono.d.cts",
        "default": "./dist/hono.cjs"
      }
    },
    "./sdk": {
      "import": {
        "types": "./dist/sdk/index.d.ts",
        "default": "./dist/sdk/index.js"
      },
      "require": {
        "types": "./dist/sdk/index.d.cts",
        "default": "./dist/sdk/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@s3-good/shared": "workspace:*",
    "sqids": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "hono": "^4.12.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@s3-good/react": "workspace:*",
    "hono": ">=4.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "@s3-good/react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clopca/aws-s3-sdk-but-good.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/clopca/aws-s3-sdk-but-good/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/clopca/aws-s3-sdk-but-good/issues"
  }
}
